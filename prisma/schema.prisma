generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Creneau {
  id             String          @id @default(uuid())
  nom            String
  dateDebut      DateTime
  dateFin        DateTime
  statut         Status
  description    String?
  capacite       Int
  dateCreation   DateTime        @default(now())
  participations Participation[]
}

model Participation {
  id            String      @id @default(uuid())
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  creneau       Creneau     @relation(fields: [creneauId], references: [id])
  dateCreation  DateTime    @default(now())
  utilisateurId String
  creneauId     String
}

model Utilisateur {
  id             String          @id @default(uuid())
  prenom         String
  nom            String
  email          String          @unique
  adresse        String
  codePostal     String
  ville          String
  motDePasse     String
  role           Role            @default(USER)
  dateCreation   DateTime        @default(now())
  participations Participation[]
  commandes      Commande[]
  paniers        Panier[]

  @@map("User")
}

model Panier {
  id             String           @id @default(uuid())
  utilisateur    Utilisateur      @relation(fields: [utilisateurId], references: [id])
  utilisateurId  String
  prix           Float
  dateCreation   DateTime         @default(now())
  produitPaniers Produit_Panier[]
}

model Produit_Panier {
  id        String  @id @default(uuid())
  panier    Panier  @relation(fields: [panierId], references: [id])
  panierId  String
  produit   Produit @relation(fields: [produitId], references: [id])
  produitId String
  quantite  Float
  unite     Float
  prix      Float
}

model Produit {
  id             String           @id @default(uuid())
  typeProduit    Type_Produit     @relation(fields: [typeProduitId], references: [id])
  typeProduitId  String
  quantite       Float
  dateArrive     DateTime
  dateSortie     DateTime?
  datePeremption DateTime?
  produitPaniers Produit_Panier[]
}

model Type_Produit {
  id               String             @id @default(uuid())
  nom              String
  quantiteMax      Float
  unite            Unite
  prix             Float
  dateCreation     DateTime           @default(now())
  commandeProduits Commande_Produit[]
  produits         Produit[]
}

model Commande_Produit {
  id            String       @id @default(uuid())
  commandeId    String
  typeProduitId String
  commande      Commande     @relation(fields: [commandeId], references: [id])
  typeProduit   Type_Produit @relation(fields: [typeProduitId], references: [id])
  quantite      Float
}

model Commande {
  id               String             @id @default(uuid())
  utilisateur      Utilisateur        @relation(fields: [utilisateurId], references: [id])
  utilisateurId    String
  dateCreation     DateTime           @default(now())
  commandeProduits Commande_Produit[]
}

enum Role {
  USER
  ADMIN
}

enum Status {
  AVANT
  EN_COURS
  FINI
}

enum Unite {
  VRAC
  UNITE
}
